{% extends 'base.html.twig' %}

{% block title %}Accueil - ResaTable{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    {% if app.user %}
        <div class="mb-3">
            Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">se déconnecter</a>
        </div>
    {% endif %}
    <h1>Page d'accueil</h1>

    This friendly message is coming from:
    <ul>
        <li>Your controller at <code>/app/src/Controller/HomeController.php</code></li>
        <li>Your template at <code>/app/templates/home/index.html.twig</code></li>
    </ul>
    <a href="{{ path('app_login') }}">Se connecter en administrateur</a>
</div>
{% endblock %}
